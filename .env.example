# ──────────────────────────────────────────────
# UOF MCP Server — 環境變數範本
# 複製本檔案為 .env 並填入實際值
# 詳細說明見 docs/configuration.md
# ──────────────────────────────────────────────

# 所有工具使用 httpx + lxml 操作 UOF 網頁端點，不需要瀏覽器 runtime。

# UOF 站台基礎 URL（必填）
# 格式：https://your-uof-domain.com/VirtualPath（不含尾斜線）
# 範例：https://your-uof-host.example.com/UOF
UOF_BASE_URL=https://your-uof-domain.com

# MCP Server 執行時的登入帳號與密碼（透過 Login.aspx 表單登入 → session cookie）
UOF_ACCOUNT=your_account
UOF_PASSWORD=your_password

# SSL 憑證驗證（true = 嚴格驗證；只有本機或自簽憑證測試環境才建議設 false）
UOF_SSL_VERIFY=true

# ──────────────────────────────────────────────
# 以下為測試專用（mounted 真實層使用，正式環境可忽略）
# 三個測試角色共用 UOF_PASSWORD；測試範圍限定這三個帳號
# ──────────────────────────────────────────────

# 具測試清理權限的帳號
UOF_ACCOUNT_USER1=
# 測試簽核帳號
UOF_ACCOUNT_USER2=
# 測試申請帳號
UOF_ACCOUNT_USER3=

# mounted 工作流程測試用的原生表單名。該表單的後台流程須將申請帳號送給測試簽核帳號。
# 留空時 mounted 會 skip。
UOF_TEST_WORKFLOW_FORM_NAME=

# 測試表單的 fields JSON 與用來寫入每次測試識別文字的欄位 ID。
# 這些值屬於部署端客製 schema，只能放在未追蹤的 .env。
UOF_TEST_WORKFLOW_FIELDS=
UOF_TEST_WORKFLOW_MEMO_FIELD=
