{
  "_comment": "每個 server entry 綁定一個 UOF 帳號；請使用安全方式提供密碼。",
  "mcpServers": {
    "uof": {
      "_comment": "第一個操作身份。",
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-uof", "run", "mcp-uof"],
      "env": {
        "UOF_BASE_URL": "https://your-uof-domain.com/VirtualPath",
        "UOF_ACCOUNT": "your_account",
        "UOF_PASSWORD": "your_password"
      }
    },
    "uof-manager": {
      "_comment": "第二個操作身份，可與第一個 entry 同時啟用。",
      "command": "uv",
      "args": ["--directory", "/absolute/path/to/mcp-uof", "run", "mcp-uof"],
      "env": {
        "UOF_BASE_URL": "https://your-uof-domain.com/VirtualPath",
        "UOF_ACCOUNT": "manager_account",
        "UOF_PASSWORD": "manager_password"
      }
    }
  }
}
